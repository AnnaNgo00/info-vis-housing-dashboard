{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Is Housing Supply Keeping Up with Price & Rent Growth?",
    "subtitle": "Regional analysis: Dublin vs Rest of Ireland",
    "anchor": "middle",
    "fontSize": 28,
    "subtitleFontSize": 16
  },

  "data": {
    "url": "https://raw.githubusercontent.com/AnnaNgo00/info-vis-housing-dashboard/main/processed_housing_master.csv"
  },

  "params": [
    {
      "name": "compareRegion",
      "value": "Dublin",
      "bind": {
        "input": "select",
        "options": ["Dublin", "Rest of Ireland"],
        "name": "Compare to National: "
      }
    }
  ],

  "transform": [
    { 
      "calculate": "toNumber(datum.Year)", 
      "as": "YearNum" 
    },
    { 
      "calculate": "toNumber(datum.Price_Growth)", 
      "as": "PriceGrowthNum" 
    },
    { 
      "calculate": "toNumber(datum.Rent_Growth)", 
      "as": "RentGrowthNum" 
    },
    { 
      "calculate": "toNumber(datum.Completions_per_1000)", 
      "as": "CompPer1000Num" 
    }
  ],

  "vconcat": [
    {
      "title": { 
        "text": "1. Price vs Rent Growth Over Time", 
        "anchor": "middle", 
        "fontSize": 20 
      },

      "transform": [
        { "filter": "datum.Region == 'National' || datum.Region == compareRegion" },
        { "calculate": "datum.Region == 'National' ? 'National (baseline)' : 'Selected region'", "as": "LineType" },
        { "filter": "isFinite(datum.YearNum)" },

        { 
          "fold": ["PriceGrowthNum", "RentGrowthNum"], 
          "as": ["Metric", "Growth"] 
        },
        { "filter": "isFinite(datum.Growth)" },
        { "filter": "datum.Growth >= 0" },

        {
          "calculate": "datum.Metric == 'PriceGrowthNum' ? 'Price Growth' : 'Rent Growth'",
          "as": "MetricLabel"
        }
      ],

      "mark": { "type": "line", "point": true, "strokeWidth": 3 },

      "encoding": {
        "x": {
          "field": "YearNum",
          "type": "quantitative",
          "title": "Year",
          "axis": { 
            "format": "d", 
            "tickMinStep": 1 
          }
        },
        "y": { 
          "field": "Growth", 
          "type": "quantitative", 
          "title": "Increase (%)",
          "scale": {
            "domainMin": 0
          } 
        },
        "color": { 
          "field": "MetricLabel", 
          "type": "nominal", 
          "title": null,
          "legend": {
            "orient": "top-right",
            "direction": "vertical",
            "offset": 10
          } 
        },
        "detail": {
          "field": "Region"
        },
        
        "opacity": {
          "condition": {
            "test": "datum.Region == compareRegion", 
            "value": 1
          },
          "value": 0.25
        },

        "strokeDash": {
  "field": "LineType",
  "type": "nominal",
  "legend": {
    "title": null,
    "orient": "none",
    "legendX": 700,
    "legendY": 10,
    "direction": "vertical"
  },
  "scale": {
    "domain": ["National (baseline)"],
    "range": [[6,4]]
  }
},
        
        "tooltip": [
          { "field": "YearNum", "title": "Year", "format": "d" },
          { "field": "MetricLabel", "title": "Metric" },
          { "field": "Growth", "title": "Value", "format": ".2f" }
        ]
      },

      "width": 1000,
      "height": 280
    },

    {
  "title": "2. Housing Supply Heatmap (Completions per 1,000)",
  "transform": [
    { "filter": "datum.Region != 'National'" },
    { "filter": "isFinite(datum.YearNum) && isFinite(datum.CompPer1000Num)" }
  ],
  "mark": "rect",
  "encoding": {
    "x": { "field": "YearNum", "type": "ordinal", "title": "Year", "axis": {
    "labelAngle": 0
  } },
    "y": { "field": "Region", "type": "nominal", "title": "Region", "axis": {
    "titleAngle": 0
  } },
    "color": { "field": "CompPer1000Num", "type": "quantitative", "title": "Per 1,000" },
    "tooltip": [
      { "field": "YearNum", "type": "ordinal", "title": "Year" },
      { "field": "Region", "type": "nominal" },
      { "field": "CompPer1000Num", "type": "quantitative", "format": ".3f", "title": "Per 1,000" }
    ]
  },
  "width": 900,
  "height": 300
},

    {
      "title": { 
        "text": "3. Supply vs Price Growth (with trendline)", 
        "anchor": "middle", 
        "fontSize": 20 
      },

      "transform": [
        { "filter": "datum.Region == 'National' || datum.Region == compareRegion" },
        { "filter": "isFinite(datum.CompPer1000Num) && isFinite(datum.PriceGrowthNum)" },
        { "filter": "abs(datum.PriceGrowthNum) <= 100" }
      ],

      "layer": [
        {
          "mark": { 
            "type": "circle", 
            "size": 120, 
            "opacity": 0.7 },

          "encoding": {
            "x": { 
              "field": "CompPer1000Num", 
              "type": "quantitative", 
              "title": "Completions per 1,000" 
            },
            "y": { 
              "field": "PriceGrowthNum", 
              "type": "quantitative", 
              "title": "Price Growth (%)" 
            },
            
            "opacity": {
              "condition": { 
                "test": "datum.Region == compareRegion", 
                "value": 0.9 
              },
              "value": 0.25
            },
            
            "tooltip": [
              { "field": "YearNum", "title": "Year", "format": "d" },
              { "field": "CompPer1000Num", "title": "Completions per 1,000", "format": ".3f" },
              { "field": "PriceGrowthNum", "title": "Price Growth (%)", "format": ".2f" }
            ]
          }
        },
        {
          "transform": [
            { 
              "loess": "PriceGrowthNum", 
              "on": "CompPer1000Num", 
              "bandwidth": 0.7 }
          ],

          "mark": { 
            "type": "line", 
            "strokeWidth": 4 
          },

          "encoding": {
            "x": { 
              "field": "CompPer1000Num", 
              "type": "quantitative" 
            },
            "y": { 
              "field": "PriceGrowthNum", 
              "type": "quantitative" 
            }
          }
        }
      ],

      "width": 1000,
      "height": 320
    }
  ],

  "config": {
    "axis": { 
      "labelFontSize": 15, 
      "titleFontSize": 16, 
      "gridOpacity": 0.2 
    },
    "legend": { 
      "labelFontSize": 15, 
      "titleFontSize": 16 
    },
    "title": { 
      "fontSize": 20 
    },
    "view": { 
      "stroke": "transparent"
    }
  }
}