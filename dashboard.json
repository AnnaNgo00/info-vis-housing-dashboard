{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Is Housing Supply Keeping Up with Price & Rent Growth?",
    "subtitle": "Click Dublin/Rest on the map to filter. Brush years on the growth chart to focus analysis."
  },
  "config": {
    "view": { "stroke": "transparent" },
    "axis": { "labelFontSize": 12, "titleFontSize": 13, "gridOpacity": 0.15 },
    "title": { "fontSize": 16 }
  },

  "params": [
    {
      "name": "metric",
      "value": "Price_Growth",
      "bind": {
        "input": "select",
        "options": ["Price_Growth", "Rent_Growth", "Completions_per_1000"],
        "name": "Map metric: "
      }
    },
    {
      "name": "year",
      "value": 2020,
      "bind": { "input": "range", "min": 2012, "max": 2025, "step": 1, "name": "Map year: " }
    },
    {
      "name": "regionClick",
      "select": { "type": "point", "fields": ["Region"], "on": "click", "toggle": true, "clear": "dblclick" }
    }
  ],

  "vconcat": [
    {
      "hconcat": [
        {
          "title": "Ireland (Dublin vs Rest of Ireland)",
          "width": 520,
          "height": 520,
          "projection": { "type": "conicConformal" },

          "data": {
            "url": "https://raw.githubusercontent.com/colmr/vis_class/master/Ireland_custom_topjson.json",
            "format": { "type": "topojson", "feature": "IRL_adm1" }
          },

          "transform": [
            { "calculate": "datum.id == 'Dublin' ? 'Dublin' : 'Rest of Ireland'", "as": "Region" },

            {
              "lookup": "Region",
              "from": {
                "data": { "url": "processed_housing_master.csv" },
                "key": "Region",
                "fields": ["Year", "Price_Growth", "Rent_Growth", "Completions_per_1000", "Completions", "Population"]
              }
            },
            { "calculate": "toNumber(datum.Year)", "as": "YearNum" },
            { "filter": "datum.YearNum == year" },
            { "calculate": "datum[metric]", "as": "MetricValue" }
          ],

          "mark": { "type": "geoshape", "stroke": "white", "strokeWidth": 0.7 },
          "encoding": {
            "color": {
              "field": "MetricValue",
              "type": "quantitative",
              "legend": { "title": null }
            },
            "opacity": { "condition": { "param": "regionClick", "value": 1 }, "value": 0.75 },
            "tooltip": [
              { "field": "id", "type": "nominal", "title": "County" },
              { "field": "Region", "type": "nominal" },
              { "field": "YearNum", "type": "quantitative", "title": "Year", "format": "d" },
              { "field": "MetricValue", "type": "quantitative", "title": "Selected metric", "format": ".2f" },
              { "field": "Price_Growth", "type": "quantitative", "format": ".2f" },
              { "field": "Rent_Growth", "type": "quantitative", "format": ".2f" },
              { "field": "Completions_per_1000", "type": "quantitative", "format": ".3f" }
            ]
          }
        },

        {
          "title": "Selected year comparison",
          "width": 420,
          "height": 520,
          "data": { "url": "processed_housing_master.csv" },
          "transform": [
            { "calculate": "toNumber(datum.Year)", "as": "YearNum" },
            { "filter": "datum.YearNum == year" },
            { "filter": "datum.Region != 'National'" },
            { "calculate": "datum[metric]", "as": "MetricValue" },
            {
              "filter": "length(data('regionClick_store')) == 0 || datum.Region == data('regionClick_store')[0].Region"
            }
          ],
          "mark": "bar",
          "encoding": {
            "y": { "field": "Region", "type": "nominal", "title": "Region", "sort": "-x" },
            "x": { "field": "MetricValue", "type": "quantitative", "title": "Value" },
            "tooltip": [
              { "field": "YearNum", "type": "quantitative", "title": "Year", "format": "d" },
              { "field": "Region", "type": "nominal" },
              { "field": "MetricValue", "type": "quantitative", "title": "Value", "format": ".2f" }
            ]
          }
        }
      ]
    },

    {
      "title": "Option A: Supply vs Growth (brush years on the top chart)",
      "data": { "url": "processed_housing_master.csv" },
      "transform": [
        { "filter": "datum.Region != 'National'" },
        {
          "filter": "length(data('regionClick_store')) == 0 || datum.Region == data('regionClick_store')[0].Region"
        },
        { "calculate": "toNumber(datum.Year)", "as": "YearNum" }
      ],
      "vconcat": [
        {
          "title": "Annual growth (Price vs Rent)",
          "params": [
            { "name": "yearBrush", "select": { "type": "interval", "encodings": ["x"] } }
          ],
          "transform": [{ "fold": ["Price_Growth", "Rent_Growth"], "as": ["Series", "Growth"] }],
          "layer": [
            { "mark": { "type": "rule", "opacity": 0.35 }, "encoding": { "y": { "datum": 0 } } },
            {
              "mark": { "type": "line", "point": true, "strokeWidth": 2 },
              "encoding": {
                "x": { "field": "YearNum", "type": "quantitative", "title": "Year", "axis": { "format": "d", "tickMinStep": 1 } },
                "y": { "field": "Growth", "type": "quantitative", "title": "Annual growth (%)" },
                "color": { "field": "Series", "type": "nominal", "title": null },
                "tooltip": [
                  { "field": "YearNum", "type": "quantitative", "title": "Year", "format": "d" },
                  { "field": "Series", "type": "nominal" },
                  { "field": "Growth", "type": "quantitative", "format": ".2f" }
                ]
              },
              "width": 980,
              "height": 220
            }
          ]
        },

        {
          "title": "Supply: completions per 1,000 population (filtered by brush)",
          "transform": [{ "filter": { "param": "yearBrush" } }],
          "mark": { "type": "line", "point": true, "strokeWidth": 2 },
          "encoding": {
            "x": { "field": "YearNum", "type": "quantitative", "title": "Year", "axis": { "format": "d", "tickMinStep": 1 } },
            "y": { "field": "Completions_per_1000", "type": "quantitative", "title": "Completions per 1,000" },
            "tooltip": [
              { "field": "YearNum", "type": "quantitative", "title": "Year", "format": "d" },
              { "field": "Completions", "type": "quantitative", "format": ",.0f" },
              { "field": "Population", "type": "quantitative", "format": ",.0f" },
              { "field": "Completions_per_1000", "type": "quantitative", "format": ".3f" }
            ]
          },
          "width": 980,
          "height": 210
        },

        {
          "title": "Relationship: does lower supply align with higher price growth? (filtered by brush)",
          "transform": [{ "filter": { "param": "yearBrush" } }],
          "layer": [
            {
              "mark": { "type": "circle", "opacity": 0.75, "size": 75 },
              "encoding": {
                "x": { "field": "Completions_per_1000", "type": "quantitative", "title": "Completions per 1,000" },
                "y": { "field": "Price_Growth", "type": "quantitative", "title": "Price growth (%)" },
                "tooltip": [
                  { "field": "YearNum", "type": "quantitative", "title": "Year", "format": "d" },
                  { "field": "Completions_per_1000", "type": "quantitative", "format": ".3f" },
                  { "field": "Price_Growth", "type": "quantitative", "format": ".2f" },
                  { "field": "Rent_Growth", "type": "quantitative", "format": ".2f" }
                ]
              },
              "width": 980,
              "height": 260
            },
            {
              "transform": [{ "regression": "Price_Growth", "on": "Completions_per_1000" }],
              "mark": { "type": "line", "strokeWidth": 3 },
              "encoding": {
                "x": { "field": "Completions_per_1000", "type": "quantitative" },
                "y": { "field": "Price_Growth", "type": "quantitative" }
              }
            }
          ]
        }
      ]
    }
  ]
}