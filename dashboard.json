{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Is Housing Supply Keeping Up with Price & Rent Growth?",
    "subtitle": "Regional analysis: Dublin vs Rest of Ireland",
    "anchor": "middle",
    "fontSize": 28,
    "subtitleFontSize": 16
  },

  "data": {
    "url": "https://raw.githubusercontent.com/AnnaNgo00/info-vis-housing-dashboard/main/processed_housing_master.csv"
  },

  "transform": [
    { "calculate": "toNumber(datum.Year)", "as": "YearNum" },
    { "calculate": "toNumber(datum.Price_Growth)", "as": "PriceGrowthNum" },
    { "calculate": "toNumber(datum.Rent_Growth)", "as": "RentGrowthNum" },
    { "calculate": "toNumber(datum.Completions_per_1000)", "as": "CompPer1000Num" }
  ],

  "config": {
    "axis": {
      "labelFontSize": 15,
      "titleFontSize": 16,
      "gridOpacity": 0.2,
      "labelPadding": 15,
      "labelOffset": 12
    },
    "legend": {
      "labelFontSize": 16,
      "titleFontSize": 16
    },
    "title": {
      "fontSize": 20
    }
  },

  "resolve": {
    "legend": {
      "color": "independent",
      "strokeDash": "independent",
      "opacity": "independent"
    }
  },

  "spacing": 50,

  "vconcat": [
    {
      "title": {
        "text": "1. National Rent Growth Over Time",
        "anchor": "middle",
        "fontSize": 25
      },

      "transform": [
        { "filter": "datum.Region == 'National'" },
        { "filter": "isFinite(datum.YearNum) && isFinite(datum.RentGrowthNum)" },
        { "filter": "datum.RentGrowthNum >= 0" }
      ],

      "mark": {
        "type": "line",
        "point": true,
        "strokeWidth": 3,
        "color": "#0072B2"
      },

      "encoding": {
        "x": {
          "field": "YearNum",
          "type": "quantitative",
          "title": "Year",
          "axis": { "format": "d", "tickMinStep": 1 }
        },
        "y": {
          "field": "RentGrowthNum",
          "type": "quantitative",
          "title": "Rent Growth (%)",
          "scale": { "domainMin": 0 },
          "axis": {
            "titleAngle": 0,
            "titlePadding": 60
          }
        },
        "tooltip": [
          { "field": "YearNum", "title": "Year", "format": "d" },
          { "field": "RentGrowthNum", "title": "Rent Growth (%)", "format": ".2f" }
        ]
      },

      "width": 900,
      "height": 280
    },

    {
      "title": {
        "text": "National vs Dublin",
        "anchor": "middle",
        "fontSize": 25
      },

      "transform": [
        { "filter": "datum.Region == 'National' || datum.Region == 'Dublin'" },
        { "filter": "isFinite(datum.YearNum)" }
      ],

      "spacing": 50,

      "vconcat": [
        {
          "title": {
            "text": "2. Supply (Completions per 1,000): National vs Dublin",
            "anchor": "middle",
            "fontSize": 20
          },

          "transform": [
            { "filter": "isFinite(datum.CompPer1000Num)" },
            {
              "aggregate": [
                { "op": "mean", "field": "CompPer1000Num", "as": "Supply" }
              ],
              "groupby": ["YearNum", "Region"]
            },
            {
              "calculate": "datum.Region == 'National' ? 'National (baseline)' : 'Dublin'",
              "as": "Series"
            }
          ],

          "mark": { "type": "line", "point": true, "strokeWidth": 3 },

          "encoding": {
            "x": {
              "field": "YearNum",
              "type": "quantitative",
              "title": "Year",
              "axis": { "format": "d", "tickMinStep": 1 }
            },
            "y": {
              "field": "Supply",
              "type": "quantitative",
              "title": "Completions per 1,000",
              "axis": { "titleAngle": 0, "titlePadding": 100 }
            },
            "color": {
              "field": "Series",
              "type": "nominal",
              "title": null,
              "scale": {
                "domain": ["National (baseline)", "Dublin"],
                "range": ["#1F77B4", "#FF7F0E"]
              },
              "legend": {
                "orient": "bottom-right",
                "direction": "vertical",
                "symbolStrokeWidth": 3
              }
            },
            "tooltip": [
              { "field": "YearNum", "title": "Year", "format": "d" },
              { "field": "Series", "title": "Series" },
              { "field": "Supply", "title": "Completions per 1,000", "format": ".3f" }
            ]
          },

          "width": 900,
          "height": 220
        },

        {
          "title": {
            "text": "3. Price Growth (%): National vs Dublin",
            "anchor": "middle",
            "fontSize": 20
          },

          "transform": [
            { "filter": "isFinite(datum.PriceGrowthNum)" },
            { "filter": "datum.PriceGrowthNum >= 0" },
            {
              "aggregate": [
                { "op": "mean", "field": "PriceGrowthNum", "as": "PriceGrowth" }
              ],
              "groupby": ["YearNum", "Region"]
            },
            {
              "calculate": "datum.Region == 'National' ? 'National (baseline)' : 'Dublin'",
              "as": "Series"
            }
          ],

          "mark": { "type": "line", "point": true, "strokeWidth": 3 },

          "encoding": {
            "x": {
              "field": "YearNum",
              "type": "quantitative",
              "title": "Year",
              "axis": { "format": "d", "tickMinStep": 1 }
            },
            "y": {
              "field": "PriceGrowth",
              "type": "quantitative",
              "title": "Price Growth (%)",
              "scale": { "domainMin": 0 },
              "axis": { "titleAngle": 0, "titlePadding": 80 }
            },
            "color": {
              "field": "Series",
              "type": "nominal",
              "title": null,
              "scale": {
                "domain": ["National (baseline)", "Dublin"],
                "range": ["#1F77B4", "#FF7F0E"]
              },
              "legend": {
                "orient": "top-right",
                "direction": "vertical",
                "symbolStrokeWidth": 3
              }
            },
            "tooltip": [
              { "field": "YearNum", "title": "Year", "format": "d" },
              { "field": "Series", "title": "Series" },
              { "field": "PriceGrowth", "title": "Price Growth (%)", "format": ".2f" }
            ]
          },

          "width": 900,
          "height": 220
        }
      ]
    },

    {
      "title": {
        "text": "4. Housing Supply Heatmap (Completions per 1,000)",
        "anchor": "middle",
        "fontSize": 25
      },

      "transform": [
        { "filter": "datum.Region != 'National'" },
        { "filter": "isFinite(datum.YearNum) && isFinite(datum.CompPer1000Num)" }
      ],

      "mark": "rect",

      "encoding": {
        "x": {
          "field": "YearNum",
          "type": "ordinal",
          "title": "Year",
          "axis": { "labelAngle": 0 }
        },
        "y": {
          "field": "Region",
          "type": "nominal",
          "title": "Region",
          "axis": { "titleAngle": 0 }
        },
        "color": {
          "field": "CompPer1000Num",
          "type": "quantitative",
          "title": "Per 1,000",
          "scale": { "scheme": "viridis" }
        },
        "tooltip": [
          { "field": "YearNum", "type": "ordinal", "title": "Year" },
          { "field": "Region", "type": "nominal" },
          { "field": "CompPer1000Num", "type": "quantitative", "format": ".3f", "title": "Per 1,000" }
        ]
      },

      "width": 900,
      "height": 280
    }
  ]
}